# Workwear Group Demo Portal — environment variables
# Copy to .env.local for local development, and set these in the Vercel project.

# Server-side Stripe secret key (test mode). Used by all /api/demo/* route handlers.
STRIPE_SECRET_KEY=sk_test_xxx

# Client-side Stripe publishable key (test mode). Used by the Payment Element.
# Must be prefixed with NEXT_PUBLIC_ so it is available in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
